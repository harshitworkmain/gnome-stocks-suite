# GNOME Stocks gitignore

# Secrets and User Configs
stocks-daemon/config.json

# Databases and Local Caches
stocks-daemon/llm_cache.db
stocks-daemon/__pycache__/
**/__pycache__/
*.pyc

# Extension compiled schemas
gnome-stocks@harshitworkmain/schemas/gschemas.compiled

# Build artifacts
*.zip
*.tar.gz
*.deb

# Logs and debug files
logs/
*.log

# System files
.DS_Store
